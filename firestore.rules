rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return userExists()
        && userDoc().data.role == "admin";
    }

    function isActiveUser() {
      return userExists()
        && userDoc().data.status == "active";
    }

    function isVerified() {
      return isSignedIn()
        && request.auth.token.email_verified == true;
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.role == "customer"
        && request.resource.data.email == request.auth.token.email;

      allow read: if isOwner(userId) || isAdmin();

      // Allow the user to update their own profile fields,
      // AND allow the verification status fields to be updated
      // when the user has verified their email in Firebase Auth.
      allow update: if isAdmin() || (
        isOwner(userId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "name",
          "phone",
          "address",
          "emailVerified",
          "status",
          "updatedAt"
        ])
        // Prevent users from escalating their own status to anything other than "active"
        // and only when their email is actually verified in Firebase Auth
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(["emailVerified", "status"])
          || (
            request.auth.token.email_verified == true
            && request.resource.data.emailVerified == true
            && request.resource.data.status in ["active", resource.data.status]
          )
        )
        // Prevent users from changing their own role
        && request.resource.data.role == resource.data.role
      );

      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;

        allow create: if isSignedIn()
          && isActiveUser()
          && isVerified()
          && request.resource.data.userId == request.auth.uid;

        allow update: if isSignedIn()
          && isActiveUser()
          && isVerified()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid;

        allow delete: if isSignedIn()
          && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create, update: if isOwner(userId)
        && isActiveUser()
        && isVerified()
        && request.resource.data.userId == request.auth.uid;

      allow delete: if isOwner(userId)
        && isActiveUser()
        && isVerified();

      match /items/{itemId} {
        allow read: if isOwner(userId) || isAdmin();

        allow create, update, delete: if isOwner(userId)
          && isActiveUser()
          && isVerified();
      }
    }

    match /orders/{orderId} {
      allow create: if isSignedIn()
        && isActiveUser()
        && isVerified()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.paymentStatus == "unpaid"
        && request.resource.data.paymentMethod == "cash_on_delivery";

      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      allow update, delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}